rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helper functions ----------
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }
    function isOrderOwner() {
      return request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ---------- Public collections ----------
    match /menu_items/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Coupons
    match /coupons/{couponId} {
      // Coupons are read by server function now, no public read needed
      allow read, write: if isAdmin();
    }

    match /tables/{tableId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reservations/{resId} {
      // Reservations are created by server function, so no public create needed
      allow read, write: if isAdmin();
    }

    // Orders
    match /orders/{orderId} {
      // Orders are created by server function
      allow read: if isAdmin() || isOrderOwner();
      allow write: if isAdmin();
    }

    match /users/{userId}/addresses/{addressId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if resource.data.status == "approved" || isAdmin();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
