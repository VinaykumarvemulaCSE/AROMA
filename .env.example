# ============================================================
#  AROMA CAFE — Environment Variables Example
#  Copy this file to .env and fill in your real values.
# ============================================================

# --- Firebase (Client - Public) ---
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# --- Google Maps Places API (Client - Public) ---
VITE_GOOGLE_MAPS_API_KEY=

# --- Cloudinary (Client - Public) ---
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# --- Application URL (Client & Server) ---
VITE_APP_URL=http://localhost:3000

# --- Server Secrets (Server-Only - DO NOT use VITE_ prefix) ---
# Admin Email for Authentication & Alerts
ADMIN_EMAIL=admin@example.com

# Nodemailer / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@example.com

# Cloudinary (Server-Only - If using server-side SDK later)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
